# =============================================================================
# QUESTPIE Autopilot — Caddy Reverse Proxy
# =============================================================================
#
# DOMAIN is passed from docker-compose.yml environment. No manual replacement needed.
# Caddy auto-provisions TLS via Let's Encrypt. No manual cert management.
#
# All routes proxy to the orchestrator API on port 7778.
# Operator surfaces: CLI, API, MCP, Telegram, query.
#
# Webhooks are on a separate subdomain for external services.
# =============================================================================

# ── Orchestrator API ────────────────────────────────────────────────────────
{$DOMAIN} {
	# All traffic → orchestrator
	reverse_proxy orchestrator:7778
}

# ── Webhooks (separate subdomain) ───────────────────────────────────────────
# Uncomment if you need external webhooks (GitHub, Slack, etc.)
# webhooks.{$DOMAIN} {
# 	reverse_proxy orchestrator:7777
# }
