# =============================================================================
# QUESTPIE Autopilot — VPS / Production Environment
# =============================================================================
# Copy to .env and fill in your values:
#   cp .env.example .env
#   nano .env

# ── Required ─────────────────────────────────────────────────────────────────

# AI Provider — OpenRouter is the simplest (one key for all models)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# ── Recommended ──────────────────────────────────────────────────────────────

# Master key for secrets encryption (generate: openssl rand -hex 32)
AUTOPILOT_MASTER_KEY=

# Better Auth secret for cookies/tokens (generate: openssl rand -hex 32)
BETTER_AUTH_SECRET=

# Public URL of this orchestrator (for notifications, preview links, worker enrollment)
# Examples:
#   ORCHESTRATOR_URL=http://YOUR_SERVER_IP:7778
#   ORCHESTRATOR_URL=https://autopilot.yourdomain.com  (if using Caddy/TLS)
# ORCHESTRATOR_URL=

# ── Optional ─────────────────────────────────────────────────────────────────

# Company data directory on host (default: ./company)
# COMPANY_ROOT=./company

# Direct provider keys (if not using OpenRouter)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_AI_API_KEY=...

# CORS origin (set when using a reverse proxy)
# CORS_ORIGIN=https://autopilot.yourdomain.com

# ── Caddy / TLS (only if using --profile reverse-proxy) ─────────────────────

# Your domain (without https://)
# DOMAIN=autopilot.yourdomain.com
