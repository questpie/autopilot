# =============================================================================
# QUESTPIE Autopilot — Production Environment
# =============================================================================
# Copy to .env and fill in your values:
#   cp .env.example .env
#   nano .env

# ── Required ─────────────────────────────────────────────────────────────────

# Your domain (without https://)
DOMAIN=autopilot.yourdomain.com

# Claude API key (or use: docker compose exec autopilot autopilot provider login claude)
ANTHROPIC_API_KEY=sk-ant-...

# ── Recommended ──────────────────────────────────────────────────────────────

# Master key for secrets encryption (generate: openssl rand -base64 32)
AUTOPILOT_MASTER_KEY=

# ── Optional ─────────────────────────────────────────────────────────────────

# Company data directory on host (default: ./company)
# COMPANY_ROOT=./company

# OpenAI API key (for Codex SDK provider)
# OPENAI_API_KEY=

# Google AI key (for Gemini embeddings)
# GOOGLE_AI_API_KEY=
