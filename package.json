{
  "name": "@questpie/autopilot",
  "version": "0.1.0",
  "description": "Local-first workflow engine for coding agents",
  "type": "module",
  "private": false,
  "author": "QUESTPIE",
  "license": "MIT",
  "packageManager": "bun@1.3.0",
  "engines": {
    "bun": ">=1.3.0"
  },
  "keywords": [
    "ai",
    "agent",
    "agents",
    "workflow",
    "cli",
    "tui",
    "planning",
    "orchestration",
    "claude",
    "codex"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/questpie/questpie-autopilot.git"
  },
  "homepage": "https://github.com/questpie/questpie-autopilot#readme",
  "bugs": {
    "url": "https://github.com/questpie/questpie-autopilot/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "qap": "./src/index.ts"
  },
  "files": [
    "src",
    "README.md",
    "ROADMAP.md",
    "SPEC.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "check": "bun test && bun run typecheck",
    "pack:dry": "npm pack --dry-run"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/react": "^19.2.14",
    "typescript": "^5.8"
  },
  "dependencies": {
    "@opentui/core": "^0.1.90",
    "@opentui/react": "^0.1.90",
    "react": "^19.2.4"
  }
}
