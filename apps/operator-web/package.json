{
	"name": "@questpie/operator-web",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"imports": {
		"#questpie": "./src/questpie/server/.generated/index.ts",
		"#questpie/*": "./src/questpie/server/.generated/*"
	},
	"scripts": {
		"dev": "bun --bun vite dev --port 3000",
		"build": "vite build",
		"start": "bun run .output/server/index.mjs",
		"preview": "bun run build && bun run preview:serve",
		"preview:serve": "NODE_ENV=production bun run .output/server/index.mjs",
		"check-types": "tsc --noEmit",
		"routes:generate": "tsr generate",
		"questpie:generate": "questpie generate -c src/questpie/server/questpie.config.ts",
		"scaffold:generate": "bun run routes:generate && bun run questpie:generate",
		"db:push": "questpie push -c questpie.config.ts",
		"migrate": "questpie migrate -c questpie.config.ts",
		"migrate:create": "questpie migrate:create -c questpie.config.ts",
		"migrate:status": "questpie migrate:status -c questpie.config.ts",
		"migrate:down": "questpie migrate:down -c questpie.config.ts",
		"migrate:reset": "questpie migrate:reset -c questpie.config.ts",
		"migrate:fresh": "questpie migrate:fresh -c questpie.config.ts",
		"scaffold:verify": "bun run scaffold:generate && bun run check-types",
		"test": "bun test --timeout 10000 --no-orphans --path-ignore-patterns='tests/scenario-harness/**' --path-ignore-patterns='tests/scenarios/phase-0/flows/**' --path-ignore-patterns='tests/scenarios/phase-0/organization-db.test.ts' tests",
		"test:phase-0": "bun run build && bun test --timeout 10000 --no-orphans --path-ignore-patterns='tests/scenarios/phase-0/organization-db.test.ts' tests/scenarios/phase-0",
		"test:scenario": "bun run build && bun test --timeout 240000 --no-orphans tests/scenarios/phase-0/flows",
		"test:scenario-harness": "bun run build && bun test --timeout 240000 --no-orphans tests/scenario-harness",
		"test:scenario-harness:serve": "bun run build && bun tests/scenario-harness/serve.ts"
	},
	"dependencies": {
		"@questpie/mcp": "3.16.0",
		"@questpie/openapi": "3.16.0",
		"@questpie/tanstack-query": "3.16.0",
		"@questpie/ui": "workspace:*",
		"@questpie/workflows": "3.16.0",
		"@t3-oss/env-core": "^0.12.0",
		"@tanstack/react-query": "^5.62.11",
		"@tanstack/react-router": "^1.132.0",
		"@tanstack/react-router-ssr-query": "1.167.1",
		"@tanstack/react-start": "^1.132.0",
		"better-auth": "^1.6.23",
		"drizzle-orm": "1.0.0-beta.6-4414a19",
		"pg": "^8.13.1",
		"pg-boss": "^12.5.4",
		"questpie": "3.16.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"zod": "^4.2.1"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.0.0",
		"@tanstack/devtools-vite": "latest",
		"@tanstack/react-devtools": "latest",
		"@tanstack/react-router-devtools": "latest",
		"@tanstack/router-cli": "^1.132.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^6.0.1",
		"bun-types": "latest",
		"drizzle-kit": "1.0.0-beta.6-4414a19",
		"nitro": "latest",
		"tailwindcss": "^4.0.0",
		"tw-animate-css": "^1.0.0",
		"typescript": "^5.9.2",
		"vite": "^8.0.0",
		"vite-tsconfig-paths": "^6.1.1"
	}
}
