	"keywords": ["questpie", "autopilot", "avatar", "generative", "svg", "deterministic"],
	"homepage": "https://autopilot.questpie.com",
	"repository": {
		"type": "git",
		"url": "https://github.com/questpie/autopilot",
		"directory": "packages/avatar"
	},
	"license": "MIT",
