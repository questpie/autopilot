{
	"name": "@questpie/autopilot-mcp",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"description": "MCP server for QUESTPIE Autopilot — expose tasks, agents, search, sessions to Claude Desktop/Code",
	"main": "src/index.ts",
	"bin": {
		"autopilot-mcp": "./src/index.ts"
	},
	"scripts": {
		"start": "bun run src/index.ts",
