# ============================================
# QUESTPIE Autopilot — Environment Variables
# ============================================

# --- Authentication ---
# Choose ONE method per provider:
#
# Option A: Subscription login (recommended)
#   Run: autopilot provider login claude
#   Run: autopilot provider login codex
#   Works on VPS too — prints a link to open on any device.
#
# Option B: API keys
#   ANTHROPIC_API_KEY=sk-ant-...
#   OPENAI_API_KEY=sk-...

# Anthropic API key (alternative to subscription login)
# ANTHROPIC_API_KEY=

# OpenAI API key (alternative to subscription login)
# OPENAI_API_KEY=

# --- Optional ---

# Company root directory (default: ./company)
# COMPANY_ROOT=./company

# API server port (default: 7778)
# PORT=7778

# Webhook server port (default: 7777)
# WEBHOOK_PORT=7777

# Dashboard port (default: 3001)
# DASHBOARD_PORT=3001

# Master encryption key for secrets (auto-generated if empty)
# Generate: openssl rand -base64 32
# AUTOPILOT_MASTER_KEY=

# Environment (development | production)
# NODE_ENV=production

# CORS allowed origin (set to your domain when behind a reverse proxy)
# Example: https://autopilot.yourdomain.com
# CORS_ORIGIN=

# Auth mode — set to true for multi-user setups
# AUTH_ENABLED=false

# Google AI API key (for Gemini embeddings — optional)
# GOOGLE_AI_API_KEY=
