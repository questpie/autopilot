# Required
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Required for Docker (path inside container)
COMPANY_ROOT=/data/company

# Recommended for production
AUTOPILOT_MASTER_KEY=       # Generate: openssl rand -base64 32
NODE_ENV=production

# Optional
PORT=7778                   # API server port
WEBHOOK_PORT=7777           # Webhook server port

# Embedding providers (optional — configure in company.yaml)
# GOOGLE_AI_API_KEY=        # For Gemini embeddings
