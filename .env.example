# ============================================
# QUESTPIE Autopilot — Environment Variables
# ============================================

# --- AI Provider (required — pick one) ---

# OpenRouter API key — one key for all models (Anthropic, OpenAI, Google, etc.)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Or use direct provider keys instead of OpenRouter:
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_AI_API_KEY=...

# --- Deployment Mode ---
# selfhosted = you provide your own API keys (default)
# cloud = QUESTPIE manages AI infrastructure
# DEPLOYMENT_MODE=selfhosted

# --- Orchestrator URL ---
# Public base URL for this orchestrator instance.
# Used in notifications, preview links, and worker enrollment instructions.
# Leave empty for local-only development (defaults to http://localhost:<PORT>).
# Set this when deploying to a VPS, behind a reverse proxy, or on a Tailscale network.
# Examples:
#   ORCHESTRATOR_URL=https://autopilot.yourdomain.com
#   ORCHESTRATOR_URL=https://autopilot.my-tailnet.ts.net
#   ORCHESTRATOR_URL=http://192.168.1.100:7778
# ORCHESTRATOR_URL=

# --- Optional ---

# Company root directory (default: ./company)
# COMPANY_ROOT=./company

# API server port (default: 7778)
# PORT=7778

# Webhook server port (default: 7777)
# WEBHOOK_PORT=7777

# Durable Streams (session persistence + live tailing)
# Dev: in-process test server on this port (default: 4437)
# Prod: set DURABLE_STREAMS_URL to external server binary
# DURABLE_STREAMS_PORT=4437
# DURABLE_STREAMS_URL=http://127.0.0.1:4437

# Master encryption key for secrets (auto-generated if empty)
# Generate: openssl rand -hex 32
# AUTOPILOT_MASTER_KEY=

# Better Auth secret for cookies/tokens (required in production)
# Generate: openssl rand -hex 32
# BETTER_AUTH_SECRET=

# Environment (development | production)
# NODE_ENV=production

# CORS allowed origin (set to your domain when behind a reverse proxy)
# Example: https://autopilot.yourdomain.com
# CORS_ORIGIN=

# Auth mode — set to true for multi-user setups
# AUTH_ENABLED=false

# --- Database (libSQL / Turso) ---
# Local file URL (default: file:<companyRoot>/.data/autopilot.db)
# For Turso cloud: libsql://your-db-name.turso.io
# DATABASE_URL=

# Turso embedded replica sync URL (optional — enables local replica with cloud sync)
# TURSO_SYNC_URL=

# Turso auth token (required for cloud databases)
# TURSO_AUTH_TOKEN=

# --- Webhooks ---
# Secret used to verify incoming webhook payloads (HMAC)
# WEBHOOK_SECRET=

# --- Plan Limits ---
# Maximum number of concurrent agents
# PLAN_MAX_AGENTS=10

# Maximum AI tokens per day
# PLAN_MAX_TOKENS_DAY=1000000
